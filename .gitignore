# =============================================================================
# .gitignore — Three-Tier EKS IAC Platform
# =============================================================================

# ── Node.js ──
node_modules/
npm-debug.log*
yarn-error.log

# ── Terraform ──
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
crash.log

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*.bak

# ── OS Generated ──
.DS_Store
Thumbs.db
desktop.ini

# ── Environment ──
.env
.env.local
.env.production

# ── Build artifacts ──
build/
dist/
